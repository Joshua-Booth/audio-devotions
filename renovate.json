{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":maintainLockFilesWeekly",
    "schedule:weekends",
    "group:allNonMajor"
  ],

  "labels": ["dependencies"],
  "baseBranchPatterns": ["master"],
  "rangeStrategy": "pin",

  "semanticCommitType": "chore",
  "semanticCommitScope": "deps",
  "commitMessageAction": "update",

  "prHourlyLimit": 5,
  "prConcurrentLimit": 10,

  "packageRules": [
    {
      "description": "Automerge non-major updates for stable packages",
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "matchCurrentVersion": "!/^0/",
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true,
      "minimumReleaseAge": "3 days"
    },
    {
      "description": "Require manual review for major updates",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["dependencies", "major"],
      "dependencyDashboardApproval": true
    },
    {
      "description": "Require review for 0.x packages",
      "matchCurrentVersion": "/^0/",
      "automerge": false,
      "labels": ["dependencies", "unstable"]
    },
    {
      "description": "Group React ecosystem",
      "matchPackageNames": ["/^react$/", "/^react-dom$/", "/^@types\\/react/"],
      "groupName": "react ecosystem"
    },
    {
      "description": "Group Storybook packages",
      "matchPackageNames": ["/^storybook/", "/^@storybook\\//"],
      "groupName": "storybook"
    },
    {
      "description": "Group testing packages",
      "matchPackageNames": [
        "/^vitest/",
        "/^@vitest\\//",
        "/^playwright/",
        "/^@playwright\\//",
        "/^@vitest-browser-playwright$/"
      ],
      "groupName": "testing tools"
    },
    {
      "description": "Group Vite packages",
      "matchPackageNames": ["/^vite$/", "/^vite-/", "/^@vitejs\\//"],
      "groupName": "vite"
    },
    {
      "description": "Group Tailwind packages",
      "matchPackageNames": ["/^tailwind/", "/^@tailwindcss\\//"],
      "groupName": "tailwindcss"
    },
    {
      "description": "Group GitHub Actions",
      "matchManagers": ["github-actions"],
      "groupName": "github actions"
    }
  ],

  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["dependencies", "security"],
    "schedule": ["at any time"],
    "automerge": true,
    "minimumReleaseAge": "0 days"
  }
}
