{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "react", "unicorn", "vitest"],
  "rules": {
    "unicorn/filename-case": [
      "error",
      {
        "cases": {
          "kebabCase": true
        }
      }
    ]
  },
  "env": {
    "browser": true
  },
  "settings": {
    "react": {
      "version": "19.0"
    }
  }
}
